{
  "compilerOptions": {
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",

    /* Vite / bundler */
    "target": "ES2022",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "useDefineForClassFields": true,
    "noEmit": true,
    "skipLibCheck": true,

    /* Single-file transpilation safety (Vite/esbuild) */
    "isolatedModules": true,
    "verbatimModuleSyntax": true,

    /* Strict family + extra AI-mistake guards (see §05 of the stack doc).
       Only useUnknownInCatchVariables is implied by "strict"; the rest are explicit. */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noImplicitOverride": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noPropertyAccessFromIndexSignature": true,
    "forceConsistentCasingInFileNames": true,

    /* Path alias — paths resolve relative to this tsconfig (TS 4.1+); no baseUrl needed. */
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"]
}
